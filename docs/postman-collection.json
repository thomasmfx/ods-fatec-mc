{
  "info": {
    "name": "ODS Mogi das Cruzes — API",
    "description": "Coleção de testes para a API do sistema de votação da 1ª Conferência Nacional ODS — Etapa Livre, Fatec Mogi das Cruzes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "sessaoToken",
      "value": "",
      "type": "string"
    }
