        {
          "name": "Opções do formulário de cadastro (200)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/sessao/opcoes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sessao",
                "opcoes"
              ]
            }
          }
        },
        {
          "name": "Check-in — participante existente (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('sessaoToken', json.sessaoToken);",
                  "  console.log('Token salvo:', json.sessaoToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos.mendes@email.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessao/checkin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sessao",
                "checkin"
              ]
            }
          }
        },
